{
    "appearance": {
        "islands": false,
        "pitchBlack": false,
        "transparency": {
            "enabled": true
        }
    },
    "background": {
        "desktopClock": {
            "enabled": true
        },
        "desktopLyrics": {
            "enabled": true
        },
        "videoWallpaperMuteOnMedia": false,
        "videoWallpaperPauseOnFullscreen": false,
        "videoWallpaperPaused": false,
        "videoWallpaperSoundEnabled": false,
        "visualiser": {
            "enabled": true
        },
        "wallpaperEnabled": true,
        "wallpaperRecolor": true,
        "wallpaperRecolorStrength": 0.5046618009868421
    },
    "bar": {
        "persistent": true
    },
    "dashboard": {
        "enabled": true,
        "showDashboard": true,
        "showOnHover": true
    },
    "launcher": {
        "favouriteApps": [
            "firefox",
            "claude-desktop"
        ],
        "maxWallpapers": 9,
        "showOnHover": false,
        "useFuzzy": {
            "wallpapers": false
        }
    },
    "paths": {
        "wallpaperDir": "~/wallpapers"
    },
    "services": {
        "audioIncrement": 0.05,
        "brightnessIncrement": 0.05,
        "defaultPlayer": "Mozilla firefox",
        "lyricsBackend": "LyricsBackend::Auto",
        "maxVolume": 1,
        "smartScheme": true,
        "useFahrenheit": false
    },
    "sidebar": {
        "enabled": true
    }
}
